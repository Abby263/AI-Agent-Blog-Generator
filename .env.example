OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=
BLOG_SERIES_MODEL=gpt-5.4-nano
BLOG_SERIES_TEMPERATURE=0.3
BLOG_SERIES_MAX_TOKENS=4000
BLOG_SERIES_OUTPUT_DIR=outputs
BLOG_SERIES_LOG_LEVEL=INFO
BLOG_SERIES_ENABLE_EVALUATION=true
BLOG_SERIES_ENABLE_MEMORY=true
BLOG_SERIES_USE_MEMORY=true
BLOG_SERIES_MAX_RETRIEVED_SKILLS=5
BLOG_SERIES_ENABLE_LANGSMITH=false
LANGSMITH_API_KEY=
BLOG_SERIES_LANGSMITH_PROJECT=blog-series-agent
BLOG_SERIES_LANGSMITH_API_KEY_ENV=LANGSMITH_API_KEY
BLOG_SERIES_LANGSMITH_ENDPOINT=
BLOG_SERIES_LANGSMITH_TRACE_PROMPTS=false
BLOG_SERIES_LANGSMITH_TRACE_ARTIFACTS=false
BLOG_SERIES_ENABLE_WEB_SEARCH=false
BLOG_SERIES_WEB_SEARCH_MAX_RESULTS=6
BLOG_SERIES_WEB_FETCH_MAX_CHARS=5000
BLOG_SERIES_WEB_MAX_FETCHES_PER_SECTION=3
BLOG_SERIES_CORS_ORIGINS=*
